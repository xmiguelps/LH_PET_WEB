@{
    ViewData["Title"] = "Painel Inicial";
}

<div class="row mb-4">
    <div class="col-12">
        <div class="card card-premium border-0" style="background: linear-gradient(120deg, var(--light-bg), #e0f2f1);">
            <div class="card-body p-4 d-flex align-items-center">
                <div class="me-4 text-primary" style="font-size: 3rem;">
                    <i class="fa-solid fa-hand-holding-medical"></i>
                </div>
                <div>
                    <h2 class="fw-bold mb-0">Olá, @ViewBag.NomeUsuario!</h2>
                    <p class="text-muted mb-0 fs-5">Você está autenticado como <strong>@ViewBag.PerfilUsuario</strong> (@ViewBag.EmailUsuario)</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card card-premium h-100 text-center p-4 border-0">
            <div class="card-body">
                <div class="text-success mb-3" style="font-size: 2.5rem;"><i class="fa-solid fa-calendar-check"></i></div>
                <h5 class="fw-bold">Agendamentos</h5>
                <p class="text-muted">Gerencie consultas, banho e tosa de forma ágil.</p>
                <a asp-controller="Atendimento" asp-action="Index" class="btn btn-outline-success mt-2 rounded-pill px-4">Acessar Agenda</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card card-premium h-100 text-center p-4 border-0">
            <div class="card-body">
                <div class="text-info mb-3" style="font-size: 2.5rem;"><i class="fa-solid fa-box-open"></i></div>
                <h5 class="fw-bold">Produtos</h5>
                <p class="text-muted">Controle de estoque, preços e imagens dos itens.</p>
                <a asp-controller="Produtos" asp-action="Index" class="btn btn-outline-info mt-2 rounded-pill px-4">Acessar Estoque</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card card-premium h-100 text-center p-4 border-0">
            <div class="card-body">
                <div class="text-warning mb-3" style="font-size: 2.5rem;"><i class="fa-solid fa-file-medical"></i></div>
                <h5 class="fw-bold">Prontuários</h5>
                <p class="text-muted">Acesse o histórico clínico e prescrições dos pets.</p>
                <a asp-controller="Atendimento" asp-action="Historico" class="btn btn-outline-warning mt-2 rounded-pill px-4">Acessar Prontuários</a>
            </div>
        </div>
    </div>
</div>