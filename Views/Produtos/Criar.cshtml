@model LH_PET_WEB.Models.Produto
@{
    ViewData["Title"] = "Cadastrar Produto";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card card-premium p-4 border-0 shadow-sm">
            <h4 class="fw-bold mb-4 border-bottom pb-2 text-primary"><i class="fa-solid fa-box-open me-2"></i> Novo Produto</h4>
            
            <form asp-action="Criar" method="post" enctype="multipart/form-data">

                <div class="mb-3">
                    <label asp-for="Nome" class="form-label fw-semibold">Nome do Produto</label>
                    <input asp-for="Nome" class="form-control form-control-premium" required />
                    <span asp-validation-for="Nome" class="text-danger small"></span>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="Preco" class="form-label fw-semibold">Preço de Venda (R$)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">R$</span>
                            <input asp-for="Preco" type="number" step="0.01" class="form-control form-control-premium border-start-0" required />
                        </div>
                        <span asp-validation-for="Preco" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Estoque" class="form-label fw-semibold">Qtd. Inicial em Estoque</label>
                        <input asp-for="Estoque" type="number" class="form-control form-control-premium" required />
                        <span asp-validation-for="Estoque" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Foto do Produto (Opcional)</label>
                    <input type="file" name="foto" class="form-control form-control-premium" accept="image/*" />
                    <div class="form-text small text-muted"><i class="fa-solid fa-circle-info me-1"></i> Apenas arquivos de imagem (.png, .jpg, .jpeg)</div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-light rounded-pill px-4 text-secondary fw-bold"><i class="fa-solid fa-arrow-left me-1"></i> Voltar</a>
                    <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold"><i class="fa-solid fa-check me-1"></i> Cadastrar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}