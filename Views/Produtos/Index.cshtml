@model IEnumerable<LH_PET_WEB.Models.Produto>
@{
    ViewData["Title"] = "Estoque e Produtos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark"><i class="fa-solid fa-box-open text-info me-2"></i> Estoque e Produtos</h2>
    <a asp-action="Criar" class="btn btn-primary rounded-pill fw-bold shadow-sm">
        <i class="fa-solid fa-plus me-1"></i> Cadastrar Produto
    </a>
</div>

<div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
    @foreach (var item in Model)
    {
        <div class="col">
            <div class="card card-premium h-100 border-0 shadow-sm overflow-hidden">
                <div class="bg-light text-center p-3 rounded" style="height: 200px; display: flex; align-items: center; justify-content: center;">
                    @if (!string.IsNullOrEmpty(item.ImagemUrl))
                    {
                        <img src="@item.ImagemUrl" alt="@item.Nome" class="w-100 h-100" style="object-fit: cover;">
                    }
                    else
                    {
                        <i class="fa-solid fa-image text-muted" style="font-size: 4rem;"></i>
                    }
                </div>
                
                <div class="card-body">
                    <h6 class="card-title fw-bold text-dark text-truncate" title="@item.Nome">@item.Nome</h6>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <span class="fs-5 fw-bold text-success">R$ @item.Preco.ToString("N2")</span>
                        
                        @if (item.Estoque <= 5)
                        {
                            <span class="badge bg-danger rounded-pill px-3 py-2">Estoque Baixo: @item.Estoque</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary rounded-pill px-3 py-2">Estoque: @item.Estoque</span>
                        }
                    </div>
                </div>
                
                <div class="card-footer bg-white border-top-0 p-3 pt-0 d-flex gap-2">
                    <a asp-action="Editar" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm w-50 rounded-pill fw-bold">
                        <i class="fa-solid fa-pen"></i> Editar
                    </a>

                    <form asp-action="Excluir" method="post" class="w-50">
                        <input type="hidden" name="id" value="@item.Id" />
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100 rounded-pill fw-bold" onclick="return confirm('Tem certeza que deseja remover este produto do estoque?');">
                            <i class="fa-solid fa-trash-can"></i> Excluir
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
    
    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5">
            <h5 class="text-muted"><i class="fa-solid fa-box-open mb-3 fs-1 d-block"></i> O estoque está vazio.</h5>
        </div>
    }
</div>