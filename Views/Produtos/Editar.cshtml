@model LH_PET_WEB.Models.Produto
@{
    ViewData["Title"] = "Editar Produto";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card card-premium p-4 border-0 shadow-sm">
            <h4 class="fw-bold mb-4 border-bottom pb-2 text-primary"><i class="fa-solid fa-pen-to-square me-2"></i> Atualizar Estoque / Produto</h4>
            
            <form asp-action="Editar" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />
                
                <input type="hidden" asp-for="ImagemUrl" />

                <div class="mb-3">
                    <label asp-for="Nome" class="form-label fw-semibold">Nome do Produto</label>
                    <input asp-for="Nome" class="form-control form-control-premium" required />
                    <span asp-validation-for="Nome" class="text-danger small"></span>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="Preco" class="form-label fw-semibold">Preço de Venda (R$)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">R$</span>
                            <input asp-for="Preco" type="number" step="0.01" class="form-control form-control-premium border-start-0" required />
                        </div>
                        <span asp-validation-for="Preco" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Estoque" class="form-label fw-semibold">Qtd. em Estoque</label>
                        <input asp-for="Estoque" type="number" class="form-control form-control-premium" required />
                        <span asp-validation-for="Estoque" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Nova Foto (Deixe em branco para manter a atual)</label>
                    <input type="file" name="foto" class="form-control form-control-premium" accept="image/*" />
                    @if(!string.IsNullOrEmpty(Model.ImagemUrl))
                    {
                        <div class="mt-2 small text-success"><i class="fa-solid fa-check"></i> Este produto já possui uma imagem salva.</div>
                    }
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-light rounded-pill px-4 text-secondary fw-bold"><i class="fa-solid fa-arrow-left me-1"></i> Voltar</a>
                    <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold"><i class="fa-solid fa-save me-1"></i> Salvar Alterações</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}