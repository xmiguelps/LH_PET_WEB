@model LH_PET_WEB.Models.Atendimento
@{
    ViewData["Title"] = "Visualizar Prontuário";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card card-premium p-4 border-0">
            <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
                <h4 class="fw-bold text-warning mb-0"><i class="fa-solid fa-file-prescription me-2"></i> Histórico do Atendimento</h4>
                <span class="badge bg-success"><i class="fa-solid fa-check me-1"></i> Concluído</span>
            </div>
            
            <div class="mb-4">
                <h6 class="text-muted fw-bold text-uppercase small">Sintomas / Histórico</h6>
                <div class="p-3 bg-light rounded-3">@Model.Prontuario</div>
            </div>

            <div class="mb-4">
                <h6 class="text-muted fw-bold text-uppercase small">Diagnóstico</h6>
                <div class="p-3 bg-light rounded-3 text-danger fw-semibold">@Model.Diagnostico</div>
            </div>

            <div class="mb-4">
                <h6 class="text-muted fw-bold text-uppercase small">Prescrição Médica</h6>
                <div class="p-3 bg-light rounded-3 border-start border-warning border-4">
                    @Html.Raw(Model.Prescricao.Replace("\n", "<br/>"))
                </div>
            </div>

            <div class="mt-4 text-center">
                <a asp-action="Index" class="btn btn-light rounded-pill px-5 text-secondary fw-bold"><i class="fa-solid fa-arrow-left me-1"></i> Voltar para Agenda</a>
            </div>
        </div>
    </div>
</div>