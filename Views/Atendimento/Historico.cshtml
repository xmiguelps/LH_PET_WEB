@model IEnumerable<LH_PET_WEB.Models.Atendimento>
@{
    ViewData["Title"] = "Histórico Clínico e Prontuários";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark"><i class="fa-solid fa-file-medical text-warning me-2"></i> Histórico de Prontuários</h2>
</div>

<div class="card card-premium p-3 border-0 mb-4">
    <form asp-action="Historico" method="get" class="row g-3 align-items-center">
        <div class="col-md-10">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0 text-muted"><i class="fa-solid fa-magnifying-glass"></i></span>
                <input type="text" name="pesquisa" value="@ViewBag.PesquisaAtual" class="form-control form-control-premium border-start-0" placeholder="Pesquisar por nome do Pet ou nome do Tutor..." />
            </div>
        </div>
        <div class="col-md-2 text-end">
            <button type="submit" class="btn btn-premium w-100 fw-bold">Buscar</button>
        </div>
    </form>
</div>

<div class="card card-premium p-0 border-0 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light text-secondary">
                <tr>
                    <th class="py-3 px-4">Data do Atendimento</th>
                    <th class="py-3">Paciente (Pet)</th>
                    <th class="py-3">Tutor Responsável</th>
                    <th class="py-3">Resumo do Diagnóstico</th>
                    <th class="py-3 text-end px-4">Ação</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="py-3 px-4 fw-semibold text-muted">@item.Agendamento?.DataHora.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="py-3 fw-bold text-primary"><i class="fa-solid fa-paw me-1"></i> @item.Agendamento?.Pet?.Nome</td>
                        <td class="py-3 text-dark">@item.Agendamento?.Pet?.Cliente?.Nome</td>
                        <td class="py-3 text-truncate" style="max-width: 250px;" title="@item.Diagnostico">
                            @item.Diagnostico
                        </td>
                        <td class="py-3 text-end px-4">
                            <a asp-action="Prontuario" asp-route-agendamentoId="@item.AgendamentoId" class="btn btn-sm btn-outline-warning rounded-pill px-3 fw-bold">
                                <i class="fa-solid fa-book-medical me-1"></i> Abrir Prontuário
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <h5 class="text-muted"><i class="fa-solid fa-folder-open mb-3 fs-1 d-block"></i> Nenhum prontuário encontrado.</h5>
            </div>
        }
    </div>
</div>