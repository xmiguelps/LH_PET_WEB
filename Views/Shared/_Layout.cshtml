<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VetPlus Care</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-premium">
            <div class="container">
                <a class="navbar-brand" asp-controller="Painel" asp-action="Index">
                    <i class="fa-solid fa-paw me-2"></i>VetPlus Care
                </a>
                <button class="navbar-toggler text-white" type="button" data-bs-toggle="collapse" data-bs-target="#menuPrincipal">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <div class="collapse navbar-collapse" id="menuPrincipal">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Painel" asp-action="Index"><i class="fa-solid fa-house me-1"></i> Início</a>
                            </li>
                            
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Configuracao" asp-action="Index"><i class="fa-solid fa-gears me-1"></i> Agenda</a>
                            </li>
                            
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Produtos" asp-action="Index"><i class="fa-solid fa-box-open me-1"></i> Estoque</a>
                            </li>
                            
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Vendas" asp-action="Historico"><i class="fa-solid fa-list-check me-1"></i> Vendas</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link fw-bold text-success" asp-controller="Vendas" asp-action="PDV"><i class="fa-solid fa-cash-register me-1"></i> Caixa</a>
                            </li>
                            
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-warning" asp-controller="Relatorios" asp-action="Index"><i class="fa-solid fa-chart-pie me-1"></i> Relatórios</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Usuarios" asp-action="Index"><i class="fa-solid fa-users-gear me-1"></i> Equipe</a>
                                </li>
                            }
                            
                            <li class="nav-item">
                                <a class="nav-link text-danger fw-bold" asp-controller="Autenticacao" asp-action="Sair">
                                    <i class="fa-solid fa-right-from-bracket me-1"></i> Sair
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4 mb-5">
        <main role="main" class="pb-3">
            @if (TempData["Sucesso"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    <i class="fa-solid fa-circle-check me-2"></i> @TempData["Sucesso"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Erro"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                    <i class="fa-solid fa-circle-exclamation me-2"></i> @TempData["Erro"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-auto py-3" style="background-color: #ffffff;">
        <div class="container text-center">
            &copy; 2026 - VetPlus Care System - Todos os direitos reservados.
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>